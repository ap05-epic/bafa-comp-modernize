# Copy to .env.local and set per environment. These point the app at the SAME backend
# endpoints the original used, so it connects identically.
#
# Auth + logging base (token flow). Original local mode used http://localhost:8080/BAA/api.
VITE_AUTH_BASE=/BAA/api
# Report data base (report-meta-data / report-customization-metadata / reports).
# Original dev|qa|prod -> the EISL compensation service. Set the real base here in the pod.
VITE_DATA_BASE=/BAA/api
# Compensation widget endpoint base (the rebuilt summary-shell widget).
VITE_COMP_BASE=/BAA/api
#
# VITE_MOCK=1  -> render from bundled sample data WITHOUT any backend (eyeball it instantly).
#                Leave UNSET for real fetches (and for the verify kit, which stubs the network).
# VITE_BASE=/BAA/businessAnalysisNext/  -> serve under the legacy shell's path.
