{
  "name": "dashboard",
  "description": "Already-built React FA Comp Summary dashboard (business-analysis-next-ui / ManagerDashboard). New metadata-driven design => parity = same-behaviour across the 3 paths (no legacy pixel baseline exists). This IS the parity ticket.",

  "target": {
    "url": "{react_base_url}{react_base_path}?reportIdentifier={reportIdentifier}&entityDisplayName={fa_context}&orgHierCode={orgHierCode}&orgHierRole={orgHierRole}&orgIdentifier={orgIdentifier}&env={env}",
    "ready_selector": ".manager-dashboard-container",
    "ready_timeout_ms": 15000
  },

  "pixel": { "enabled": false },

  "journeys": [
    {
      "id": "happy",
      "title": "Happy path - valid selection renders the report",
      "stubs": {
        "token": "auth_token.json",
        "report_meta": "report_meta_data.json",
        "report_customization": "report_customization_metadata.json",
        "reports": "reports_happy.json",
        "log": "__ok__"
      },
      "asserts": [
        { "type": "visible", "selector": ".manager-dashboard-container" },
        { "type": "visible", "selector": ".ag-theme-alpine" },
        { "type": "text_present", "text": "FA Comp Summary Dashboard" },
        { "type": "text_present", "text": "FA ID" },
        { "type": "text_present", "text": "Name" },
        { "type": "text_present", "text": "Export to Excel" },
        { "type": "text_present", "text": "Demonstrative purposes only." },
        { "type": "row_count_min", "selector": ".ag-row", "min": 2 }
      ],
      "screenshot": "dashboard_happy.png"
    },
    {
      "id": "validation_nodata",
      "title": "Validation / no-data - empty selection shows the no-data message",
      "stubs": {
        "token": "auth_token.json",
        "report_meta": "report_meta_data.json",
        "report_customization": "report_customization_metadata.json",
        "reports": "reports_nodata.json",
        "log": "__ok__"
      },
      "asserts": [
        { "type": "text_equals", "selector": ".error-message-text", "text": "There is no data for your selection." }
      ],
      "screenshot": "dashboard_nodata.png"
    },
    {
      "id": "backend_error",
      "title": "Backend error - report service fails -> technical-issue message, no crash",
      "stubs": {
        "token": "auth_token.json",
        "report_meta": "report_meta_data.json",
        "report_customization": "report_customization_metadata.json",
        "reports": "__500__",
        "log": "__ok__"
      },
      "asserts": [
        { "type": "text_contains", "selector": ".error-message-text", "text": "There was a technical issue which prevented the launch of FA Comp Summary Dashboard" }
      ],
      "screenshot": "dashboard_error.png"
    }
  ]
}
